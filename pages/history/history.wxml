<!--pages/history/history.wxml - 历史记录页UI·新中式极简风-->
<view class="container">

  <!-- 标题区域 -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="back-icon">←</text>
      <text class="back-text">返回</text>
    </view>
    <text class="title">历史记录</text>
    <view class="header-right" bindtap="toggleEditMode">
      <text class="edit-text">{{isEditing ? '取消' : '编辑'}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{historyList.length == 0}}">
    <view class="empty-icon">卦</view>
    <text class="empty-text">暂无学习记录</text>
    <text class="empty-hint">完成一次排盘后，记录将显示在这里</text>
  </view>

  <!-- 历史记录列表 -->
  <view class="history-list" wx:else>
    <view
      class="history-item {{item.selected ? 'selected' : ''}}"
      wx:for="{{historyList}}"
      wx:key="id"
      data-index="{{index}}"
      bindtap="onViewDetail"
    >
      <!-- 选择框（编辑模式） -->
      <view class="checkbox" wx:if="{{isEditing}}">
        <view class="checkbox-inner {{item.selected ? 'checked' : ''}}">
          <text wx:if="{{item.selected}}" class="checkmark">✓</text>
        </view>
      </view>

      <!-- 记录内容 -->
      <view class="record-content">
        <view class="record-header">
          <text class="record-gua-name">{{item.guaName}}</text>
          <text class="record-date">{{item.date}}</text>
        </view>
        <view class="record-footer">
          <text class="record-gua-xuhao">第{{item.guaXuhao}}卦</text>
          <text class="record-arrow" wx:if="{{!isEditing}}">›</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作栏（编辑模式） -->
  <view class="action-bar" wx:if="{{isEditing && historyList.length > 0}}">
    <button class="btn-delete" bindtap="deleteSelected">
      删除选中 ({{selectedIndexes.length}})
    </button>
  </view>

  <!-- 清空按钮（非编辑模式） -->
  <view class="clear-section" wx:elif="{{historyList.length > 0}}">
    <button class="btn-clear" bindtap="clearAllHistory">
      清空所有记录
    </button>
  </view>

  <!-- 底部提示 -->
  <view class="footer" wx:if="{{historyList.length > 0}}">
    <text class="footer-text">共 {{historyList.length}} 条记录</text>
  </view>
</view>
