/* pages/history/history.wxss - 历史记录页样式·古朴神秘风 */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(180deg, #1A0F0A 0%, #2C1810 40%, #1A0F0A 100%);
  padding: 0 30rpx 30rpx;
}

/* 标题区域 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(139, 105, 20, 0.3);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #C8A96E;
}

.back-text {
  font-size: 28rpx;
  color: #C8A96E;
  letter-spacing: 2rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #D4A847;
  letter-spacing: 8rpx;
}

.header-right {
  padding: 8rpx 20rpx;
}

.edit-text {
  font-size: 28rpx;
  color: rgba(232, 213, 181, 0.7);
  letter-spacing: 2rpx;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 3rpx solid rgba(139, 105, 20, 0.2);
  border-top: 3rpx solid #C8A96E;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(232, 213, 181, 0.5);
  letter-spacing: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: rgba(232, 213, 181, 0.6);
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: rgba(232, 213, 181, 0.35);
  text-align: center;
  letter-spacing: 2rpx;
}

/* 历史记录列表 */
.history-list {
  flex: 1;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(30, 20, 12, 0.8);
  border-radius: 10rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(139, 105, 20, 0.25);
  transition: all 0.2s ease;
  position: relative;
}

.history-item:active {
  background: rgba(139, 105, 20, 0.1);
}

.history-item.selected {
  background: rgba(139, 105, 20, 0.15);
  border-color: rgba(139, 105, 20, 0.5);
}

/* 历史记录左侧装饰条 */
.history-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  bottom: 20%;
  width: 4rpx;
  background: linear-gradient(180deg, transparent, #8B6914, transparent);
  border-radius: 2rpx;
}

/* 选择框 */
.checkbox {
  margin-right: 20rpx;
}

.checkbox-inner {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(139, 105, 20, 0.4);
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(30, 20, 12, 0.5);
}

.checkbox-inner.checked {
  background: #8B6914;
  border-color: #8B6914;
}

.checkmark {
  font-size: 24rpx;
  color: #E8D5B5;
  font-weight: bold;
}

/* 记录内容 */
.record-content {
  flex: 1;
  padding-left: 8rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.record-date {
  font-size: 24rpx;
  color: rgba(232, 213, 181, 0.5);
  letter-spacing: 2rpx;
}

.record-gua-name {
  font-size: 30rpx;
  color: #D4A847;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-gua-xuhao {
  font-size: 22rpx;
  color: rgba(232, 213, 181, 0.35);
  letter-spacing: 2rpx;
}

.record-arrow {
  font-size: 22rpx;
  color: rgba(139, 105, 20, 0.4);
}

/* 操作栏 */
.action-bar {
  padding: 24rpx 0;
}

.btn-delete {
  width: 100%;
  padding: 24rpx;
  font-size: 28rpx;
  background: rgba(139, 37, 0, 0.2);
  color: #C87850;
  border: 1rpx solid rgba(139, 37, 0, 0.4);
  border-radius: 8rpx;
  letter-spacing: 4rpx;
  line-height: 1.4;
}

.btn-delete:active {
  background: rgba(139, 37, 0, 0.35);
}

/* 清空按钮 */
.clear-section {
  padding: 24rpx 0;
}

.btn-clear {
  width: 100%;
  padding: 20rpx;
  font-size: 26rpx;
  background: rgba(139, 37, 0, 0.08);
  color: rgba(200, 120, 80, 0.7);
  border: 1rpx solid rgba(139, 37, 0, 0.25);
  border-radius: 8rpx;
  letter-spacing: 4rpx;
  line-height: 1.4;
}

.btn-clear:active {
  background: rgba(139, 37, 0, 0.15);
}

/* 底部提示 */
.footer {
  padding: 24rpx 0;
  text-align: center;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(232, 213, 181, 0.3);
  letter-spacing: 4rpx;
}
