/* pages/history/history.wxss - 历史记录页样式·新中式极简风 */

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #F8F5F0;
  padding: 0 32rpx 32rpx;
  box-sizing: border-box;
}

/* 标题区域 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #E8E0D6;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-icon {
  font-size: 32rpx;
  color: #8C8377;
}

.back-text {
  font-size: 28rpx;
  color: #8C8377;
}

.title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2C2C2C;
  letter-spacing: 6rpx;
}

.header-right {
  padding: 8rpx 20rpx;
}

.edit-text {
  font-size: 26rpx;
  color: #C45A3C;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #E8E0D6;
  border-top: 3rpx solid #C45A3C;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #A89E94;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 40rpx;
}

.empty-icon {
  font-size: 72rpx;
  color: #D4CFC8;
  margin-bottom: 24rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #8C8377;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #A89E94;
  text-align: center;
}

/* 历史记录列表 */
.history-list {
  flex: 1;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
}

.history-item:active {
  opacity: 0.85;
}

.history-item.selected {
  border-left: 4rpx solid #C45A3C;
  background: #FDF2EF;
}

/* 选择框 */
.checkbox {
  margin-right: 20rpx;
}

.checkbox-inner {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #E8E0D6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  transition: all 0.2s;
}

.checkbox-inner.checked {
  background: #C45A3C;
  border-color: #C45A3C;
}

.checkmark {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* 记录内容 */
.record-content {
  flex: 1;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.record-date {
  font-size: 22rpx;
  color: #A89E94;
}

.record-gua-name {
  font-size: 30rpx;
  color: #2C2C2C;
  font-weight: bold;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.record-gua-xuhao {
  font-size: 22rpx;
  color: #A89E94;
}

.record-arrow {
  font-size: 28rpx;
  color: #D4CFC8;
  font-weight: bold;
}

/* 操作栏 */
.action-bar {
  padding: 24rpx 0;
}

.btn-delete {
  width: 100%;
  padding: 22rpx;
  font-size: 28rpx;
  background: #FDF2EF;
  color: #C45A3C;
  border-radius: 24rpx;
  letter-spacing: 2rpx;
  line-height: 1.4;
}

.btn-delete:active {
  opacity: 0.85;
}

/* 清空按钮 */
.clear-section {
  padding: 24rpx 0;
}

.btn-clear {
  width: 100%;
  padding: 20rpx;
  font-size: 26rpx;
  background: transparent;
  color: #A89E94;
  border: 1rpx solid #E8E0D6;
  border-radius: 24rpx;
  letter-spacing: 2rpx;
  line-height: 1.4;
}

.btn-clear:active {
  opacity: 0.85;
}

/* 底部提示 */
.footer {
  padding: 24rpx 0;
  text-align: center;
}

.footer-text {
  font-size: 22rpx;
  color: #A89E94;
}
