<!--pages/index/index.wxml - 首页UI结构·新中式极简风-->
<view class="container">

  <!-- 标题区域 -->
  <view class="header">
    <text class="title">六爻占卜</text>
    <text class="subtitle">诚心起卦 · 天机指引</text>
  </view>

  <!-- 龟壳区域 -->
  <view class="shell-area">
    <!-- 起卦仪式提示层 -->
    <view class="ritual-overlay" wx:if="{{showRitual}}" bindtap="onRitualTap">
      <view class="ritual-content">
        <view class="ritual-icon">☯</view>
        <text class="ritual-title">诚心起卦</text>
        <view class="ritual-divider"></view>
        <text class="ritual-hint">默念所求之事</text>
        <text class="ritual-hint">摇动龟壳或点击起卦</text>
        <view class="ritual-btn">
          <text>点击开始</text>
        </view>
      </view>
    </view>

    <!-- 龟壳图片 -->
    <view
      class="shell-wrapper {{turtleShaking ? 'shell-shaking' : ''}} {{currentYaoIndex >= 6 ? 'shell-done' : ''}}"
      bindtap="onTurtleTap"
    >
      <image
        class="shell-image"
        src="/images/guixiao.gif"
        mode="aspectFit"
      />
      <!-- 龟壳中心文字 -->
      <view class="shell-overlay">
        <text wx:if="{{!isDivining && currentYaoIndex == 0 && !showRitual}}" class="shell-text">起卦</text>
        <text wx:elif="{{isDivining}}" class="shell-text anim-pulse">卜</text>
        <text wx:elif="{{currentYaoIndex >= 6}}" class="shell-text shell-text-done">成</text>
        <text wx:elif="{{!showRitual}}" class="shell-text">续</text>
      </view>
    </view>

    <!-- 铜钱掉落动画 -->
    <view class="coins-area" wx:if="{{isDivining}}">
      <view class="coin coin-1"></view>
      <view class="coin coin-2"></view>
      <view class="coin coin-3"></view>
    </view>

    <!-- 摇一摇提示 -->
    <view class="shake-hint" wx:if="{{!isDivining && canClick && currentYaoIndex < 6 && !showRitual}}">
      <view class="shake-icon">⟳</view>
      <text class="shake-text">摇一摇 · 点击龟壳</text>
    </view>
  </view>

  <!-- 爻位显示区域 -->
  <view class="yao-display-area card" wx:if="{{yaoDisplay.length > 0}}">
    <view
      class="yao-item {{item.isChange ? 'yao-change' : ''}}"
      wx:for="{{yaoDisplay}}"
      wx:key="position"
    >
      <view class="yao-pos-label">{{item.position}}</view>
      <view class="yao-line-area">
        <!-- 阳爻 -->
        <view wx:if="{{item.yinYang == '阳'}}" class="yang-yao">
          <view class="yao-bar"></view>
        </view>
        <!-- 阴爻 -->
        <view wx:elif="{{item.yinYang == '阴'}}" class="yin-yao">
          <view class="yao-bar left"></view>
          <view class="yao-gap"></view>
          <view class="yao-bar right"></view>
        </view>
      </view>
      <view class="yao-info-area">
        <text class="yao-type-label">{{item.typeName}}</text>
        <text wx:if="{{item.isChange}}" class="yao-bian-mark">变</text>
      </view>
    </view>
  </view>

  <!-- 进度显示 -->
  <view class="progress-area" wx:if="{{currentYaoIndex > 0 && currentYaoIndex < 7}}">
    <view class="progress-track">
      <view class="progress-fill" style="width: {{progress}}%"></view>
      <view class="progress-jewel" style="left: {{progress}}%"></view>
    </view>
    <text class="progress-label">{{progressText}}</text>
  </view>

  <!-- 当前爻结果提示 -->
  <view class="current-result" wx:if="{{showResult && currentYaoResult != null}}">
    <view class="result-plate">
      <text class="result-yao">第{{currentYaoIndex}}爻</text>
      <text class="result-type">
        {{currentYaoResult == 0 ? '老阴 ⚋' : currentYaoResult == 1 ? '少阳 ⚊' : currentYaoResult == 2 ? '少阴 ⚋' : '老阳 ⚊'}}
      </text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-area" wx:if="{{currentYaoIndex >= 6}}">
    <view class="btn-restart" bindtap="onTurtleTap">
      <text>重新起卦</text>
    </view>
  </view>

  <!-- 底部 -->
  <view class="footer">
    <view class="divider">
      <view class="divider-line"></view>
      <view class="divider-icon">☶</view>
      <view class="divider-line"></view>
    </view>
    <text class="footer-text">三硬币法 · 共摇六次</text>
    <text class="footer-hint">老阴老阳为变爻</text>
  </view>

  <!-- 历史记录按钮 -->
  <view class="btn-history-fixed" bindtap="onViewHistory">
    <text>历史记录</text>
  </view>
</view>
