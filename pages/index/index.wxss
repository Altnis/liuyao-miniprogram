/* pages/index/index.wxss - 首页样式·古朴神秘风 + 真实龟壳图片 + 铜钱掉落动画 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 30rpx 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #1A0F0A 0%, #2C1810 40%, #1A0F0A 100%);
  position: relative;
  overflow: hidden;
}

/* 背景暗纹 */
.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(ellipse 600rpx 400rpx at 50% 35%, rgba(200, 169, 110, 0.06) 0%, transparent 70%),
    radial-gradient(circle 300rpx at 20% 70%, rgba(139, 37, 0, 0.04) 0%, transparent 70%),
    radial-gradient(circle 300rpx at 80% 70%, rgba(139, 37, 0, 0.04) 0%, transparent 70%);
  pointer-events: none;
}

/* ===== 顶部装饰 ===== */
.top-ornament {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding-top: 20rpx;
  opacity: 0.3;
}

.ornament-center {
  margin: 0 30rpx;
}

.ba-gua {
  font-size: 48rpx;
  color: #C8A96E;
}

/* ===== 标题区域 ===== */
.header {
  text-align: center;
  margin: 20rpx 0 30rpx;
  position: relative;
  z-index: 1;
}

.title {
  display: block;
  font-size: 64rpx;
  font-weight: bold;
  color: #D4A847;
  text-shadow: 0 4rpx 12rpx rgba(212, 168, 71, 0.3),
               0 1rpx 0 #8B6914;
  letter-spacing: 16rpx;
  margin-bottom: 12rpx;
}

.title-underline {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
}

.underline-seal {
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #D4A847, transparent);
  border-radius: 2rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(232, 213, 181, 0.5);
  letter-spacing: 8rpx;
}

/* ===== 龟壳区域 ===== */
.shell-area {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 20rpx 0 40rpx;
  z-index: 1;
}

/* 外层光晕 */
.shell-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -55%);
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(212, 168, 71, 0.08) 0%, transparent 70%);
  pointer-events: none;
  transition: all 0.5s ease;
}

.glow-active {
  background: radial-gradient(circle, rgba(212, 168, 71, 0.25) 0%, transparent 70%);
}

/* 龟壳包裹层 - 用于摇晃动画 + 底部投影层 */
.shell-wrapper {
  position: relative;
  width: 380rpx;
  height: 340rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  overflow: visible;
}

/* 龟壳底部投影层（悬浮感） */
.shell-wrapper::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 20rpx;
  background: radial-gradient(ellipse, rgba(0, 0, 0, 0.5) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
  z-index: -1;
}

/* 真实龟壳图片 - 透明背景 + 投影立体感 */
.shell-image {
  width: 340rpx;
  height: 300rpx;
  border-radius: 20rpx;
  /* 多重投影营造立体感：主阴影 + 环境光 + 高光 */
  filter: drop-shadow(0 8rpx 16rpx rgba(0, 0, 0, 0.6))
          drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.4))
          drop-shadow(0 16rpx 32rpx rgba(0, 0, 0, 0.3));
  /* mix-blend-mode 确保白色边缘在深色背景上自然融合 */
  mix-blend-mode: normal;
}

/* 龟壳上的文字覆盖层 */
.shell-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.shell-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #D4A847;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.9),
               0 0 20rpx rgba(212, 168, 71, 0.4);
  letter-spacing: 8rpx;
}

.anim-pulse {
  animation: pulse 0.8s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.05); }
}

.shell-wrapper:active {
  transform: scale(0.96);
}

.shell-done .shell-text {
  color: #FFD700;
  text-shadow: 0 0 16rpx rgba(255, 215, 0, 0.6),
               0 0 30rpx rgba(255, 215, 0, 0.3);
}

/* 龟壳摇晃动画 */
.shell-shaking {
  animation: shellShake 0.8s cubic-bezier(0.36, 0.07, 0.19, 0.97);
}

@keyframes shellShake {
  0%   { transform: rotate(0deg) translate(0, 0); }
  10%  { transform: rotate(-12deg) translate(-6rpx, 2rpx); }
  20%  { transform: rotate(12deg) translate(6rpx, -2rpx); }
  30%  { transform: rotate(-10deg) translate(-4rpx, 3rpx); }
  40%  { transform: rotate(10deg) translate(4rpx, -3rpx); }
  50%  { transform: rotate(-6deg) translate(-2rpx, 2rpx); }
  60%  { transform: rotate(6deg) translate(2rpx, -2rpx); }
  70%  { transform: rotate(-3deg) translate(-1rpx, 1rpx); }
  80%  { transform: rotate(3deg) translate(1rpx, -1rpx); }
  90%  { transform: rotate(-1deg); }
  100% { transform: rotate(0deg); }
}

/* ===== 铜钱掉落动画 ===== */
.coins-area {
  position: absolute;
  top: 10%;
  left: 50%;
  width: 0;
  height: 0;
  pointer-events: none;
  z-index: 10;
}

.coin {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #FFD700, #B8860B, #8B6914);
  border: 3rpx solid #D4A847;
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.5),
    inset 0 1rpx 2rpx rgba(255, 215, 0, 0.4);
  animation: coinDrop 0.8s ease-in forwards;
}

/* 铜钱中间方孔 */
.coin::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10rpx;
  height: 10rpx;
  background: #1A0F0A;
  transform: translate(-50%, -50%);
  border: 1rpx solid #8B6914;
}

/* 3枚铜钱从龟壳中掉落，略有偏移和延迟 */
.coin-1 {
  left: -60rpx;
  animation-delay: 0s;
  animation: coinDrop1 0.8s ease-in forwards;
}

.coin-2 {
  left: -10rpx;
  animation-delay: 0.1s;
  animation: coinDrop2 0.9s ease-in forwards;
}

.coin-3 {
  left: 40rpx;
  animation-delay: 0.2s;
  animation: coinDrop3 1.0s ease-in forwards;
}

@keyframes coinDrop1 {
  0%   { top: 0rpx; opacity: 1; transform: rotate(0deg); }
  30%  { opacity: 1; }
  60%  { top: 120rpx; transform: rotate(180deg); opacity: 0.9; }
  80%  { top: 160rpx; transform: rotate(300deg); opacity: 0.6; }
  100% { top: 200rpx; transform: rotate(360deg); opacity: 0; }
}

@keyframes coinDrop2 {
  0%   { top: 0rpx; opacity: 1; transform: rotate(0deg); }
  30%  { opacity: 1; }
  60%  { top: 140rpx; transform: rotate(-180deg); opacity: 0.9; }
  80%  { top: 180rpx; transform: rotate(-300deg); opacity: 0.6; }
  100% { top: 220rpx; transform: rotate(-360deg); opacity: 0; }
}

@keyframes coinDrop3 {
  0%   { top: 0rpx; opacity: 1; transform: rotate(0deg); }
  30%  { opacity: 1; }
  60%  { top: 100rpx; transform: rotate(200deg); opacity: 0.9; }
  80%  { top: 150rpx; transform: rotate(350deg); opacity: 0.6; }
  100% { top: 190rpx; transform: rotate(400deg); opacity: 0; }
}

/* ===== 起卦仪式提示层 ===== */
.ritual-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
  pointer-events: auto;
}

.ritual-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 60rpx;
  background: linear-gradient(180deg, rgba(30, 20, 12, 0.95) 0%, rgba(20, 12, 8, 0.98) 100%);
  border: 2rpx solid rgba(212, 168, 71, 0.4);
  border-radius: 16rpx;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.6),
    0 0 60rpx rgba(212, 168, 71, 0.1),
    inset 0 1rpx 0 rgba(212, 168, 71, 0.1);
  animation: ritualFadeIn 0.6s ease both;
}

@keyframes ritualFadeIn {
  from { opacity: 0; transform: translateY(20rpx) scale(0.95); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

.ritual-icon {
  font-size: 56rpx;
  color: #D4A847;
  margin-bottom: 20rpx;
  text-shadow: 0 0 20rpx rgba(212, 168, 71, 0.4);
  animation: ritualPulse 2s ease-in-out infinite;
}

@keyframes ritualPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.7; transform: scale(1.08); }
}

.ritual-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #D4A847;
  letter-spacing: 12rpx;
  margin-bottom: 24rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.ritual-divider {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #D4A847, transparent);
  margin-bottom: 24rpx;
}

.ritual-hint {
  font-size: 28rpx;
  color: rgba(232, 213, 181, 0.8);
  letter-spacing: 6rpx;
  line-height: 1.8;
  text-align: center;
}

.ritual-btn {
  margin-top: 32rpx;
  padding: 18rpx 50rpx;
  background: linear-gradient(180deg, rgba(212, 168, 71, 0.2) 0%, rgba(139, 105, 20, 0.15) 100%);
  border: 1rpx solid rgba(212, 168, 71, 0.5);
  border-radius: 8rpx;
  animation: ritualBtnPulse 2s ease-in-out infinite;
}

.ritual-btn text {
  font-size: 28rpx;
  color: #D4A847;
  letter-spacing: 8rpx;
}

@keyframes ritualBtnPulse {
  0%, 100% { box-shadow: 0 0 0 rgba(212, 168, 71, 0); }
  50% { box-shadow: 0 0 20rpx rgba(212, 168, 71, 0.2); }
}

/* 摇一摇提示 */
.shake-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  gap: 8rpx;
  animation: fadeInUp 1s ease 0.5s both;
}

.shake-icon {
  font-size: 28rpx;
  color: rgba(212, 168, 71, 0.6);
  animation: rotateHint 2s ease-in-out infinite;
}

@keyframes rotateHint {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-20deg); }
  75% { transform: rotate(20deg); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.shake-text {
  font-size: 24rpx;
  color: rgba(212, 168, 71, 0.5);
  letter-spacing: 4rpx;
}

/* ===== 爻位展示卷轴 ===== */
.yao-display-area {
  width: 100%;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.scroll-frame {
  position: relative;
  border: 2rpx solid rgba(139, 105, 20, 0.4);
  border-radius: 8rpx;
  overflow: hidden;
}

.scroll-top,
.scroll-bottom {
  height: 16rpx;
  background: linear-gradient(90deg, #3E3020, #5C4A2E, #3E3020);
  border: 1rpx solid rgba(139, 105, 20, 0.3);
}

.scroll-body {
  background: rgba(30, 20, 12, 0.9);
  padding: 20rpx 24rpx;
}

.yao-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(139, 105, 20, 0.15);
}

.yao-item:last-child {
  border-bottom: none;
}

.yao-change {
  background: rgba(139, 37, 0, 0.08);
  border-radius: 6rpx;
  padding: 12rpx 8rpx;
}

.yao-pos-label {
  width: 60rpx;
  font-size: 26rpx;
  color: rgba(212, 168, 71, 0.8);
  text-align: center;
  font-weight: bold;
}

.yao-line-area {
  flex: 1;
  display: flex;
  justify-content: center;
  padding: 0 24rpx;
}

.yang-yao {
  display: flex;
  align-items: center;
  width: 220rpx;
  height: 32rpx;
}

.yang-yao .yao-bar {
  width: 100%;
  height: 10rpx;
  background: linear-gradient(90deg, #8B6914, #D4A847, #8B6914);
  border-radius: 2rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.4);
}

.yin-yao {
  display: flex;
  align-items: center;
  width: 220rpx;
  height: 32rpx;
  justify-content: space-between;
}

.yin-yao .yao-bar {
  width: 42%;
  height: 10rpx;
  background: linear-gradient(90deg, #8B6914, #D4A847, #8B6914);
  border-radius: 2rpx;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.4);
}

.yin-yao .yao-gap {
  width: 16%;
}

.yao-info-area {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 120rpx;
  justify-content: flex-end;
}

.yao-type-label {
  font-size: 24rpx;
  color: rgba(232, 213, 181, 0.7);
}

.yao-bian-mark {
  font-size: 20rpx;
  color: #8B2500;
  font-weight: bold;
  padding: 2rpx 10rpx;
  background: rgba(139, 37, 0, 0.15);
  border: 1rpx solid rgba(139, 37, 0, 0.3);
  border-radius: 4rpx;
}

/* ===== 进度显示 ===== */
.progress-area {
  width: 100%;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.progress-track {
  position: relative;
  width: 100%;
  height: 8rpx;
  background: rgba(139, 105, 20, 0.2);
  border-radius: 4rpx;
  overflow: visible;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B6914, #D4A847);
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.progress-jewel {
  position: absolute;
  top: 50%;
  width: 20rpx;
  height: 20rpx;
  background: radial-gradient(circle, #D4A847, #8B6914);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 10rpx rgba(212, 168, 71, 0.4);
  transition: left 0.5s ease;
}

.progress-label {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: rgba(232, 213, 181, 0.6);
  letter-spacing: 2rpx;
}

/* ===== 当前爻结果 ===== */
.current-result {
  width: 100%;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.result-plate {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: rgba(139, 37, 0, 0.1);
  border: 2rpx solid rgba(139, 37, 0, 0.4);
  border-radius: 12rpx;
  position: relative;
}

.result-plate::before {
  content: '';
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 24rpx;
  height: 24rpx;
  border-top: 3rpx solid #8B2500;
  border-right: 3rpx solid #8B2500;
}

.result-yao {
  font-size: 26rpx;
  color: rgba(232, 213, 181, 0.7);
  margin-bottom: 8rpx;
}

.result-type {
  font-size: 44rpx;
  color: #D4A847;
  font-weight: bold;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.4);
}

/* ===== 操作按钮 ===== */
.action-area {
  display: flex;
  gap: 24rpx;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 1;
}

.btn-ancient {
  padding: 18rpx 40rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  text-align: center;
  letter-spacing: 4rpx;
  position: relative;
  overflow: hidden;
}

.btn-ancient::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(212, 168, 71, 0.1), transparent);
  transition: left 0.5s ease;
}

.btn-ancient:active::after {
  left: 100%;
}

.btn-history {
  background: rgba(139, 105, 20, 0.15);
  color: #C8A96E;
  border: 1rpx solid rgba(139, 105, 20, 0.4);
}

.btn-history:active {
  background: rgba(139, 105, 20, 0.3);
}

.btn-restart {
  background: rgba(139, 37, 0, 0.15);
  color: #C87850;
  border: 1rpx solid rgba(139, 37, 0, 0.4);
}

.btn-restart:active {
  background: rgba(139, 37, 0, 0.3);
}

/* ===== 底部 ===== */
.footer {
  margin-top: auto;
  text-align: center;
  padding: 20rpx 0;
  position: relative;
  z-index: 1;
}

.divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(139, 105, 20, 0.3), transparent);
}

.divider-icon {
  margin: 0 20rpx;
  color: rgba(139, 105, 20, 0.4);
  font-size: 24rpx;
}

.footer-text {
  display: block;
  font-size: 22rpx;
  color: rgba(232, 213, 181, 0.35);
  margin-bottom: 6rpx;
  letter-spacing: 4rpx;
}

.footer-hint {
  display: block;
  font-size: 20rpx;
  color: rgba(139, 37, 0, 0.5);
  letter-spacing: 2rpx;
}

/* ===== 固定底部历史记录按钮 ===== */
.btn-history-fixed {
  position: fixed;
  bottom: 40rpx;
  right: 30rpx;
  z-index: 100;
  padding: 18rpx 36rpx;
  font-size: 26rpx;
  color: #C8A96E;
  background: rgba(30, 20, 12, 0.92);
  border: 1rpx solid rgba(139, 105, 20, 0.4);
  border-radius: 8rpx;
  text-align: center;
  letter-spacing: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.5);
}
