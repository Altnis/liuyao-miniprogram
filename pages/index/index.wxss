/* pages/index/index.wxss - 首页样式·新中式极简风 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 32rpx 120rpx;
  min-height: 100vh;
  background: #F8F5F0;
  position: relative;
}

/* ===== 标题区域 ===== */
.header {
  text-align: center;
  margin: 40rpx 0 48rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #2C2C2C;
  letter-spacing: 12rpx;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #A89E94;
  letter-spacing: 6rpx;
}

/* ===== 龟壳区域 ===== */
.shell-area {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

/* 龟壳包裹层 */
.shell-wrapper {
  position: relative;
  width: 320rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  overflow: visible;
  transition: transform 0.15s ease;
}

.shell-wrapper:active {
  transform: scale(0.96);
}

/* 龟壳图片 */
.shell-image {
  width: 300rpx;
  height: 260rpx;
  border-radius: 16rpx;
  filter: drop-shadow(0 8rpx 16rpx rgba(0, 0, 0, 0.08));
}

/* 龟壳上的文字覆盖层 */
.shell-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.shell-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 8rpx;
  text-shadow:
    0 2rpx 6rpx rgba(0, 0, 0, 0.6),
    0 0 16rpx rgba(196, 90, 60, 0.4);
}

.shell-text-done {
  color: #F5EDE4;
  text-shadow:
    0 2rpx 6rpx rgba(0, 0, 0, 0.6),
    0 0 16rpx rgba(184, 149, 106, 0.4);
}

.anim-pulse {
  animation: pulse 0.8s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.04); }
}

/* 龟壳摇晃动画 */
.shell-shaking {
  animation: shellShake 0.8s cubic-bezier(0.36, 0.07, 0.19, 0.97);
}

@keyframes shellShake {
  0%   { transform: rotate(0deg) translate(0, 0); }
  10%  { transform: rotate(-8deg) translate(-4rpx, 1rpx); }
  20%  { transform: rotate(8deg) translate(4rpx, -1rpx); }
  30%  { transform: rotate(-6deg) translate(-3rpx, 2rpx); }
  40%  { transform: rotate(6deg) translate(3rpx, -2rpx); }
  50%  { transform: rotate(-4deg) translate(-2rpx, 1rpx); }
  60%  { transform: rotate(4deg) translate(2rpx, -1rpx); }
  70%  { transform: rotate(-2deg) translate(-1rpx, 1rpx); }
  80%  { transform: rotate(2deg) translate(1rpx, -1rpx); }
  90%  { transform: rotate(-1deg); }
  100% { transform: rotate(0deg); }
}

/* ===== 铜钱掉落动画 ===== */
.coins-area {
  position: absolute;
  top: 10%;
  left: 50%;
  width: 0;
  height: 0;
  pointer-events: none;
  z-index: 10;
}

.coin {
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #D4A847, #B8956A);
  border: 2rpx solid #B8956A;
  animation: coinDrop 0.8s ease-in forwards;
}

.coin::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 8rpx;
  height: 8rpx;
  background: #F8F5F0;
  transform: translate(-50%, -50%);
}

.coin-1 {
  left: -48rpx;
  animation-delay: 0s;
  animation: coinDrop1 0.8s ease-in forwards;
}

.coin-2 {
  left: -8rpx;
  animation-delay: 0.1s;
  animation: coinDrop2 0.9s ease-in forwards;
}

.coin-3 {
  left: 32rpx;
  animation-delay: 0.2s;
  animation: coinDrop3 1.0s ease-in forwards;
}

@keyframes coinDrop1 {
  0%   { top: 0rpx; opacity: 1; transform: rotate(0deg); }
  30%  { opacity: 1; }
  60%  { top: 100rpx; transform: rotate(180deg); opacity: 0.8; }
  100% { top: 160rpx; transform: rotate(360deg); opacity: 0; }
}

@keyframes coinDrop2 {
  0%   { top: 0rpx; opacity: 1; transform: rotate(0deg); }
  30%  { opacity: 1; }
  60%  { top: 110rpx; transform: rotate(-180deg); opacity: 0.8; }
  100% { top: 180rpx; transform: rotate(-360deg); opacity: 0; }
}

@keyframes coinDrop3 {
  0%   { top: 0rpx; opacity: 1; transform: rotate(0deg); }
  30%  { opacity: 1; }
  60%  { top: 90rpx; transform: rotate(200deg); opacity: 0.8; }
  100% { top: 150rpx; transform: rotate(400deg); opacity: 0; }
}

/* ===== 起卦仪式提示层 ===== */
.ritual-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
  pointer-events: auto;
}

.ritual-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 56rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
  animation: ritualFadeIn 0.4s ease both;
}

@keyframes ritualFadeIn {
  from { opacity: 0; transform: translateY(16rpx) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

.ritual-icon {
  font-size: 48rpx;
  color: #C45A3C;
  margin-bottom: 16rpx;
}

.ritual-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2C2C2C;
  letter-spacing: 8rpx;
  margin-bottom: 20rpx;
}

.ritual-divider {
  width: 60rpx;
  height: 2rpx;
  background: #E8E0D6;
  margin-bottom: 20rpx;
}

.ritual-hint {
  font-size: 26rpx;
  color: #8C8377;
  letter-spacing: 4rpx;
  line-height: 1.8;
  text-align: center;
}

.ritual-btn {
  margin-top: 28rpx;
  padding: 16rpx 56rpx;
  background: #FDF2EF;
  border-radius: 24rpx;
  white-space: nowrap;
}

.ritual-btn text {
  font-size: 26rpx;
  color: #C45A3C;
  letter-spacing: 6rpx;
}

/* 摇一摇提示 */
.shake-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  gap: 8rpx;
  animation: fadeInUp 0.8s ease 0.3s both;
}

.shake-icon {
  font-size: 26rpx;
  color: #B8956A;
  animation: rotateHint 2s ease-in-out infinite;
}

@keyframes rotateHint {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-15deg); }
  75% { transform: rotate(15deg); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.shake-text {
  font-size: 22rpx;
  color: #A89E94;
  letter-spacing: 3rpx;
}

/* ===== 爻位展示卡片 ===== */
.yao-display-area {
  width: 100%;
  margin-bottom: 24rpx;
}

.yao-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F0EBE4;
}

.yao-item:last-child {
  border-bottom: none;
}

.yao-change {
  background: #FDF2EF;
  border-radius: 12rpx;
  margin: 4rpx -8rpx;
  padding: 14rpx 8rpx;
  border-bottom: none;
}

.yao-pos-label {
  width: 56rpx;
  font-size: 24rpx;
  color: #A89E94;
  text-align: center;
  font-weight: bold;
}

.yao-line-area {
  flex: 1;
  display: flex;
  justify-content: center;
  padding: 0 20rpx;
}

.yang-yao {
  display: flex;
  align-items: center;
  width: 200rpx;
  height: 28rpx;
}

.yang-yao .yao-bar {
  width: 100%;
  height: 8rpx;
  background: linear-gradient(90deg, #C45A3C, #D4775E);
  border-radius: 4rpx;
}

.yin-yao {
  display: flex;
  align-items: center;
  width: 200rpx;
  height: 28rpx;
  justify-content: space-between;
}

.yin-yao .yao-bar {
  width: 42%;
  height: 8rpx;
  background: linear-gradient(90deg, #C45A3C, #D4775E);
  border-radius: 4rpx;
}

.yin-yao .yao-gap {
  width: 16%;
}

.yao-info-area {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 100rpx;
  justify-content: flex-end;
}

.yao-type-label {
  font-size: 22rpx;
  color: #8C8377;
}

.yao-bian-mark {
  font-size: 20rpx;
  color: #C45A3C;
  font-weight: bold;
  padding: 2rpx 10rpx;
  background: #FDF2EF;
  border-radius: 6rpx;
}

/* ===== 进度显示 ===== */
.progress-area {
  width: 100%;
  margin-bottom: 24rpx;
}

.progress-track {
  position: relative;
  width: 100%;
  height: 6rpx;
  background: #E8E0D6;
  border-radius: 3rpx;
  overflow: visible;
  margin-bottom: 14rpx;
}

.progress-fill {
  height: 100%;
  background: #C45A3C;
  border-radius: 3rpx;
  transition: width 0.5s ease;
}

.progress-jewel {
  position: absolute;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  background: #C45A3C;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: left 0.5s ease;
}

.progress-label {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #A89E94;
  letter-spacing: 2rpx;
}

/* ===== 当前爻结果 ===== */
.current-result {
  width: 100%;
  margin-bottom: 24rpx;
}

.result-plate {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.result-yao {
  font-size: 24rpx;
  color: #A89E94;
  margin-bottom: 8rpx;
}

.result-type {
  font-size: 36rpx;
  color: #C45A3C;
  font-weight: bold;
}

/* ===== 操作按钮 ===== */
.action-area {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.btn-restart {
  padding: 18rpx 56rpx;
  font-size: 26rpx;
  color: #C45A3C;
  background: #FDF2EF;
  border-radius: 24rpx;
  letter-spacing: 4rpx;
}

.btn-restart:active {
  opacity: 0.85;
}

/* ===== 底部 ===== */
.footer {
  margin-top: auto;
  text-align: center;
  padding: 20rpx 0;
}

.footer-text {
  display: block;
  font-size: 22rpx;
  color: #A89E94;
  margin-bottom: 6rpx;
  letter-spacing: 3rpx;
}

.footer-hint {
  display: block;
  font-size: 20rpx;
  color: #B8956A;
  letter-spacing: 2rpx;
}

/* ===== 固定底部历史记录按钮 ===== */
.btn-history-fixed {
  position: fixed;
  bottom: 40rpx;
  right: 32rpx;
  z-index: 100;
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  color: #8C8377;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  letter-spacing: 4rpx;
}

.btn-history-fixed:active {
  opacity: 0.85;
}
