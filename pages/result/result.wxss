/* pages/result/result.wxss - 结果页样式·新中式极简风 */

.container {
  padding: 24rpx 32rpx 160rpx;
  min-height: 100vh;
  background: #F8F5F0;
  box-sizing: border-box;
}

/* ===== 卦名区域 ===== */
.gua-header {
  text-align: center;
  margin: 16rpx 0 32rpx;
}

.gua-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #C45A3C;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
}

.gua-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.gua-type {
  font-size: 24rpx;
  color: #B8956A;
  padding: 4rpx 14rpx;
  background: #FDF2EF;
  border-radius: 8rpx;
}

.gua-time {
  font-size: 24rpx;
  color: #A89E94;
}

/* ===== 卦图展示 ===== */
.gua-diagram {
  padding: 24rpx;
}

.yao-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.yao-position {
  width: 80rpx;
  font-size: 24rpx;
  color: #A89E94;
  text-align: center;
}

.yao-line {
  flex: 1;
  display: flex;
  justify-content: center;
}

.yang-line {
  display: flex;
  align-items: center;
  width: 200rpx;
}

.yang-line .line-bar {
  width: 100%;
  height: 8rpx;
  background: linear-gradient(90deg, #C45A3C, #D4775E);
  border-radius: 4rpx;
}

.yin-line {
  display: flex;
  align-items: center;
  width: 200rpx;
  justify-content: space-between;
}

.yin-line .line-bar {
  width: 42%;
  height: 8rpx;
  background: linear-gradient(90deg, #C45A3C, #D4775E);
  border-radius: 4rpx;
}

.yin-line .line-space {
  width: 16%;
}

.yao-marks {
  display: flex;
  gap: 6rpx;
  min-width: 80rpx;
  justify-content: flex-end;
}

.mark-shi,
.mark-ying,
.mark-change {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.mark-shi {
  color: #C45A3C;
  background: #FDF2EF;
  font-weight: bold;
}

.mark-ying {
  color: #B8956A;
  background: #F5EDE4;
  font-weight: bold;
}

.mark-change {
  color: #8C8377;
  background: #F0EBE4;
}

/* ===== 六爻详析 ===== */
.table-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #2C2C2C;
  margin-bottom: 20rpx;
}

.yao-detail-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.yao-detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 16rpx;
  background: #FAFAF8;
  border-radius: 12rpx;
}

.row-shi {
  background: #FDF2EF;
  border-left: 4rpx solid #C45A3C;
}

.row-ying {
  background: #F5EDE4;
  border-left: 4rpx solid #B8956A;
}

.detail-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.detail-position {
  font-size: 24rpx;
  color: #8C8377;
  min-width: 64rpx;
}

.detail-ganzhi {
  font-size: 26rpx;
  color: #2C2C2C;
  font-weight: bold;
  min-width: 56rpx;
}

.detail-wuxing {
  font-size: 24rpx;
  color: #B8956A;
  min-width: 40rpx;
}

.detail-liuqin {
  font-size: 24rpx;
  color: #8C8377;
  min-width: 56rpx;
}

.detail-liushen {
  font-size: 24rpx;
  color: #A89E94;
}

.detail-tags {
  display: flex;
  gap: 6rpx;
}

.tag-shi {
  color: #C45A3C;
  background: #FDF2EF;
}

.tag-ying {
  color: #B8956A;
  background: #F5EDE4;
}

/* ===== 变爻信息 ===== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.toggle-icon {
  font-size: 32rpx;
  color: #A89E94;
  width: 40rpx;
  text-align: center;
}

.bianyao-detail {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0EBE4;
}

.biangua-name {
  display: block;
  font-size: 28rpx;
  color: #2C2C2C;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.bianyao-desc-text {
  font-size: 26rpx;
  color: #8C8377;
  line-height: 1.6;
}

/* ===== Tab 区域 ===== */
.tab-scroll {
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #F0EBE4;
}

.tab-list {
  display: flex;
  white-space: nowrap;
  padding-bottom: 0;
}

.tab-item {
  display: inline-flex;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #A89E94;
  position: relative;
  flex-shrink: 0;
}

.tab-item.active {
  color: #C45A3C;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 24rpx;
  right: 24rpx;
  height: 4rpx;
  background: #C45A3C;
  border-radius: 2rpx;
}

.tab-content {
  padding-top: 8rpx;
}

/* ===== 内容区块 ===== */
.content-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.content-block {
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F5F2ED;
}

.content-block:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.content-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #2C2C2C;
  margin-bottom: 10rpx;
}

.content-subtitle {
  display: block;
  font-size: 26rpx;
  color: #C45A3C;
  margin-bottom: 8rpx;
}

.content-text {
  display: block;
  font-size: 26rpx;
  color: #3D3D3D;
  line-height: 1.7;
}

/* 爻辞卡片 */
.yaoci-card {
  padding: 20rpx;
  background: #FAFAF8;
  border-radius: 12rpx;
}

.yaoci-card-change {
  background: #FDF2EF;
}

.yaoci-card-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.yaoci-card-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #2C2C2C;
}

.yao-bian-mark {
  font-size: 20rpx;
  color: #C45A3C;
  padding: 2rpx 10rpx;
  background: #FDF2EF;
  border-radius: 6rpx;
  font-weight: bold;
}

.yaoci-card-text {
  display: block;
  font-size: 26rpx;
  color: #3D3D3D;
  line-height: 1.6;
}

.yaoci-card-xiaoxiang {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #F0EBE4;
}

.xiaoxiang-label {
  font-size: 24rpx;
  color: #B8956A;
  font-weight: bold;
}

.xiaoxiang-text {
  font-size: 24rpx;
  color: #8C8377;
  line-height: 1.6;
}

/* 键值对列表 */
.kv-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 8rpx;
}

.kv-row {
  display: flex;
  gap: 16rpx;
}

.kv-label {
  font-size: 24rpx;
  color: #B8956A;
  min-width: 64rpx;
  flex-shrink: 0;
  font-weight: bold;
}

.kv-value {
  font-size: 24rpx;
  color: #3D3D3D;
  line-height: 1.6;
}

/* ===== 五行分析 ===== */
.wuxing-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* ===== 操作按钮 ===== */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #E8E0D6;
  z-index: 100;
}

.action-buttons button {
  flex: 1;
  padding: 18rpx 0;
  font-size: 26rpx;
  border-radius: 24rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.btn-restart {
  background: #C45A3C !important;
  color: #FFFFFF !important;
}

.btn-history {
  background: #FDF2EF !important;
  color: #C45A3C !important;
}

.btn-share {
  background: #F5EDE4 !important;
  color: #B8956A !important;
}

button:active {
  opacity: 0.85;
}
